<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Hệ thống quản lý</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <style>
        :root {
            --xanh-chinh: #326e51;
            --xanh-nhat: #eef4f1;
            --xanh-hover: #3d8361;
            --xanh-dam: #25523c;
            --chu-trang: #ffffff;
            --sidebar-width: 320px;
        }

        body {
            background-color: #f4f7f6;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            display: flex;
            font-size: 16px;
        }

        /* --- MENU DỌC (SIDEBAR) --- */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background-color: var(--xanh-chinh);
            position: fixed;
            left: 0;
            top: 0;
            color: white;
            box-shadow: 4px 0 15px rgba(0,0,0,0.15);
            z-index: 1000;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column; /* Cho phép footer sidebar nằm dưới cùng */
        }

        .sidebar-header {
            padding: 40px 20px;
            font-size: 1.8em;
            font-weight: 800;
            text-align: center;
            letter-spacing: 2px;
            background-color: var(--xanh-dam);
            border-bottom: 2px solid rgba(255,255,255,0.05);
        }

        /* --- USER INFO SECTION --- */
        .user-panel {
            padding: 20px;
            background: rgba(0,0,0,0.15);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .user-avatar {
            width: 50px;
            height: 50px;
            background: #ffd700;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--xanh-dam);
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .user-info .user-name {
            display: block;
            font-weight: bold;
            font-size: 1.1em;
            color: white;
        }

        .user-info .user-role {
            display: block;
            font-size: 0.8em;
            color: #ffd700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .sidebar-nav {
            list-style: none;
            padding: 10px 0;
            margin: 0;
            flex-grow: 1; /* Đẩy mục đăng xuất xuống dưới cùng nếu cần */
        }

        .sidebar-nav li a {
            display: flex;
            align-items: center;
            padding: 18px 30px;
            color: rgba(255,255,255,0.9);
            text-decoration: none;
            font-size: 1.1em;
            font-weight: 500;
            transition: all 0.3s;
            border-bottom: 1px solid rgba(255,255,255,0.03);
        }

        .sidebar-nav li a i {
            width: 40px;
            font-size: 1.3rem;
            margin-right: 10px;
            text-align: center;
        }

        .sidebar-nav li a:hover {
            background-color: var(--xanh-hover);
            color: #fff;
            padding-left: 40px;
        }

        .sidebar-nav li a:hover i {
            transform: scale(1.2);
            color: #ffd700;
        }

        /* --- NỘI DUNG CHÍNH --- */
        .main-content {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            padding: 30px;
        }

        .body-content {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 6px 20px rgba(50, 110, 81, 0.1);
            min-height: 85vh;
        }

        h2 { color: var(--xanh-chinh); font-weight: bold; }

        footer { text-align: center; color: #777; padding: 30px 0; }

        .logout-item a {
            background-color: rgba(211, 47, 47, 0.2) !important;
            color: #ff8a8a !important;
            border-top: 1px solid rgba(255,255,255,0.1);
        }

        .logout-item a:hover {
            background-color: #d32f2f !important;
            color: white !important;
        }

        @@media (max-width: 768px) {
            :root { --sidebar-width: 80px; }
            .sidebar-header span, .nav-text, .user-info { display: none; }
            .sidebar-nav li a i { margin-right: 0; width: 100%; font-size: 1.6rem; }
            .user-panel { justify-content: center; padding: 15px 5px; }
        }
    </style>
</head>
<body>

    <nav class="sidebar">
        <div class="sidebar-header">
            <i class="fas fa-leaf"></i> <span>HASAKI SHOP</span>
        </div>

        <div class="user-panel">
            <div class="user-avatar">
                <i class="fas fa-user-shield"></i>
            </div>
            <div class="user-info">
                @if (Session["MaNV"] != null)
                {
                    <span class="user-name">@Session["TenNV"]</span>
                    <span class="user-role">@Session["Quyen"]</span>
                }
                else
                {
                    <span class="user-name">Chưa đăng nhập</span>
                    <a href="@Url.Action("Login", "Account")" style="color: #ffd700; font-size: 0.8em; text-decoration: none;">Đăng nhập ngay</a>
                }
            </div>
        </div>

        <ul class="sidebar-nav">
            <li>
                <a href="@Url.Action("Index", "tbl_SanPham")">
                    <i class="fas fa-cubes"></i>
                    <span class="nav-text">Quản lý sản phẩm</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "tbl_DonHang")">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="nav-text">Quản lý bán hàng</span>
                </a>
            </li>
            @if (Session["Quyen"] != null && Session["Quyen"].ToString() == "Admin")
            {
        <li>
            <a href="@Url.Action("Index", "tbl_NguoiDung")">
                <i class="fas fa-users-cog"></i>
                <span class="nav-text">Quản lý người dùng</span>
            </a>
        </li>}
            <li>
                <a href="@Url.Action("Index", "BaoCao")">
                    <i class="fas fa-chart-pie"></i>
                    <span class="nav-text">Báo cáo & Thống kê</span>
                </a>
            </li>

            <li class="logout-item">
                <a href="@Url.Action("Logout", "Account")">
                    <i class="fas fa-power-off"></i>
                    <span class="nav-text">ĐĂNG XUẤT</span>
                </a>
            </li>
        </ul>
    </nav>

    <div class="main-content">
        <div class="container-fluid body-content">
            @RenderBody()
            <hr />
            <footer>
                <p>&copy; @DateTime.Now.Year - <strong>Hệ Thống Quản Lý Nội Bộ HASAKI</strong></p>
            </footer>
        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>