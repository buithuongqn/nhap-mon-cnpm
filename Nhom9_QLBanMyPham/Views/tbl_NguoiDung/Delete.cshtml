@model Nhom9_QLBanMyPham.Models.tbl_NguoiDung

@{
    ViewBag.Title = "Xác nhận xóa nhân viên";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Khung bao quanh trang xóa */
    .delete-container {
        max-width: 700px;
        margin: 40px auto;
        background: #fff;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        border-top: 6px solid #ff5252; /* Màu đỏ cảnh báo */
    }

    /* Tiêu đề cảnh báo */
    .warning-title {
        color: #ff5252;
        font-weight: bold;
        text-align: center;
        margin-bottom: 25px;
    }

    /* Tối ưu danh sách thông tin */
    .dl-horizontal dt {
        color: #e91e63; /* Màu hồng chủ đạo */
        padding-bottom: 10px;
        font-weight: 600;
        text-align: left;
    }

    .dl-horizontal dd {
        padding-bottom: 10px;
        border-bottom: 1px dashed #f8bbd0;
        margin-bottom: 10px;
        color: #333;
    }

    /* Nút Xóa (Màu đỏ) */
    .btn-delete-confirm {
        background-color: #ff5252;
        color: white;
        padding: 10px 25px;
        border-radius: 20px;
        border: none;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-delete-confirm:hover {
            background-color: #d32f2f;
            box-shadow: 0 4px 12px rgba(255, 82, 82, 0.4);
            color: white;
        }

    /* Nút Quay lại */
    .btn-back {
        color: #888;
        text-decoration: none;
        margin-left: 15px;
        font-weight: 500;
    }

        .btn-back:hover {
            color: #e91e63;
        }

    .action-group {
        text-align: center;
        margin-top: 30px;
    }
</style>

<div class="delete-container">
    <h2 class="warning-title">
        <i class="glyphicon glyphicon-warning-sign"></i> XÁC NHẬN XÓA
    </h2>
    <h3 class="text-center text-muted">Bạn có chắc chắn muốn xóa nhân viên này không?</h3>
    <hr />

    <div class="info-content">
        <dl class="dl-horizontal">
            <dt>Tên nhân viên</dt>
            <dd>@Html.DisplayFor(model => model.sTenNV)</dd>

            <dt>Số điện thoại</dt>
            <dd>@Html.DisplayFor(model => model.sSDT)</dd>

            <dt>Vai trò</dt>
            <dd>@Html.DisplayFor(model => model.sVaiTro)</dd>

            <dt>Quyền hạn</dt>
            <dd>
                <span class="label label-danger">@Html.DisplayFor(model => model.sPhanQuyen)</span>
            </dd>

            <dt>Lương cơ bản</dt>
            <dd class="text-danger" style="font-weight:bold">
                @String.Format("{0:N0}", Model.fLuong) VNĐ
            </dd>
        </dl>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="action-group">
            <button type="submit" class="btn-delete-confirm">
                <i class="glyphicon glyphicon-trash"></i> XÓA NGAY
            </button>

            <a href="@Url.Action("Index")" class="btn-back">
                <i class="glyphicon glyphicon-arrow-left"></i> Quay lại danh sách
            </a>
        </div>
    }
</div>