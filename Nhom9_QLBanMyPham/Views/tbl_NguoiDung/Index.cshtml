@model IEnumerable<Nhom9_QLBanMyPham.Models.tbl_NguoiDung>

@{
    ViewBag.Title = "Quản lý người dùng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* 1. CẤU TRÚC CHÍNH */
    .manage-container {
        width: 100%;
        padding: 30px;
        background-color: #fff;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0,0,0,0.07);
        margin-top: 10px;
        box-sizing: border-box;
    }

    body {
        background-color: #f4f7f6;
        font-family: 'Segoe UI', Arial, sans-serif;
    }

    /* 2. TIÊU ĐỀ */
    .header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    .header-title h2 {
        color: #326e51;
        font-weight: 800;
        margin: 0;
        font-size: 32px;
        border-left: 6px solid #326e51;
        padding-left: 15px;
    }

    /* 3. THẺ THỐNG KÊ NHANH */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: #fff;
        padding: 20px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .stat-info p {
        color: #64748b;
        font-size: 14px;
        margin: 0;
        font-weight: 600;
    }

    .stat-info h3 {
        font-weight: 800;
        margin: 5px 0 0 0;
        color: #1a1a1a;
        font-size: 24px;
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .bg-light-green {
        background: #f0fff4;
        color: #326e51;
    }

    .bg-light-blue {
        background: #ebf8ff;
        color: #2b6cb0;
    }

    /* 4. THANH TÌM KIẾM & NÚT BẤM */
    .filter-section {
        background: #f8fafc;
        padding: 15px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        border: 1px solid #cbd5e1;
    }

    .btn-action {
        height: 45px;
        font-size: 15px;
        font-weight: 700;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: 0.3s;
        border: none;
    }

    .btn-submit {
        background-color: #326e51;
        color: white !important;
        text-decoration: none;
    }

        .btn-submit:hover {
            background-color: #26553e;
            transform: translateY(-2px);
        }

    /* 5. BẢNG DỮ LIỆU */
    .table-custom thead th {
        background: #f1f5f9;
        color: #326e51;
        font-weight: 700;
        font-size: 15px;
        padding: 15px;
        text-transform: uppercase;
        border: none;
        text-align: center;
    }

    .table-custom tbody td {
        padding: 15px;
        vertical-align: middle;
        font-size: 16px;
        border-bottom: 1px solid #f1f5f9;
        text-align: center;
    }

    /* Vai trò & Badge */
    .badge-role {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        background: #e6eee9;
        color: #326e51;
        border: 1px solid #326e51;
    }

    .action-links a {
        font-size: 18px;
        margin: 0 8px;
        transition: 0.2s;
        display: inline-block;
        text-decoration: none;
    }

        .action-links a:hover {
            transform: scale(1.2);
        }

    .text-edit {
        color: #f59e0b;
    }

    .text-delete {
        color: #ef4444;
    }
</style>

<div class="manage-container">
    <div class="header-flex">
        <div class="header-title">
            <h2><i class="fa fa-users-cog"></i> Quản lý nhân viên</h2>
            <p class="text-muted mt-2">Quản lý danh sách nhân sự và phân quyền hệ thống</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-submit btn-action" style="width: 220px;">
            <i class="fa fa-user-plus"></i> Thêm nhân viên mới
        </a>
    </div>

    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-info">
                <p>Tổng nhân sự</p>
                <h3>@Model.Count()</h3>
            </div>
            <div class="stat-icon bg-light-green"><i class="fa fa-users"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <p>Quản trị viên</p>
                <h3>@Model.Count(x => x.sPhanQuyen.ToLower().Contains("admin") || x.sVaiTro.ToLower().Contains("quản lý"))</h3>
            </div>
            <div class="stat-icon bg-light-blue"><i class="fa fa-user-shield"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <p>Tổng quỹ lương</p>
                <h3>@String.Format("{0:N0}", Model.Sum(x => x.fLuong)) đ</h3>
            </div>
            <div class="stat-icon bg-light-green"><i class="fa fa-wallet"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <p>Lương TB</p>
                <h3>@String.Format("{0:N0}", (Model.Any() ? Model.Average(x => x.fLuong) : 0)) đ</h3>
            </div>
            <div class="stat-icon bg-light-blue"><i class="fa fa-chart-line"></i></div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-custom">
            <thead>
                <tr>
                    <th>Họ tên</th>
                    <th>Số điện thoại</th>
                    <th>Vai trò</th>
                    <th>Phân quyền</th>
                    <th>Mức lương</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="font-weight:700; color: #1e293b; text-align: left;">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <div style="width: 35px; height: 35px; background: #326e51; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px;">
                                    @item.sTenNV.Substring(0, 1).ToUpper()
                                </div>
                                @Html.DisplayFor(modelItem => item.sTenNV)
                            </div>
                        </td>
                        <td><i class="fa fa-phone-alt" style="font-size: 12px; color: #94a3b8;"></i> @item.sSDT</td>
                        <td><span class="text-secondary">@item.sVaiTro</span></td>
                        <td>
                            <span class="badge-role">@item.sPhanQuyen</span>
                        </td>
                        <td style="font-weight:800; color: #1a1a1a;">
                            @String.Format("{0:N0}", item.fLuong) đ
                        </td>
                        <td class="action-links">
                            <a href="@Url.Action("Edit", new { id=item.PK_sMaNV })" class="text-edit" title="Chỉnh sửa">
                                <i class="fa fa-edit"></i>
                            </a>
                            <a href="@Url.Action("Delete", new { id=item.PK_sMaNV })" class="text-delete" title="Xóa">
                                <i class="fa fa-trash-alt"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>