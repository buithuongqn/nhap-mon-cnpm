@model Nhom9_QLBanMyPham.Models.tbl_NguoiDung

@{
    ViewBag.Title = "Thêm mới nhân viên";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Bo góc và đổ bóng cho khung nhập liệu */
    .create-card {
        max-width: 800px;
        margin: 30px auto;
        background: #fff;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        /* Đổi sang màu xanh chủ đạo #326e51 */
        border-top: 6px solid #326e51;
    }

    /* Tiêu đề xanh đậm */
    h2 {
        color: #326e51;
        font-weight: bold;
        text-align: center;
        text-transform: uppercase;
        margin-bottom: 5px;
    }

    h4 {
        text-align: center;
        color: #666;
        font-weight: normal;
        margin-bottom: 30px;
    }

    /* Tối ưu các label */
    .control-label {
        color: #326e51;
        font-weight: 600 !important;
        text-align: left !important;
        padding-left: 35px !important; /* Giúp chữ không dính sát mép trái */
    }

    /* Tùy chỉnh ô nhập liệu */
    .form-control {
        border-radius: 8px;
        border: 1px solid #c8d6cf; /* Màu xanh nhạt để hài hòa */
        transition: all 0.3s;
        height: 40px;
        /* Thêm 2 dòng dưới đây */
        width: 100% !important;
        max-width: 100% !important;
    }

        .form-control:focus {
            border-color: #326e51;
            box-shadow: 0 0 8px rgba(50, 110, 81, 0.2);
        }

    /* Nút Submit xanh chuyên nghiệp */
    .btn-submit {
        background-color: #326e51;
        color: white;
        padding: 12px 30px;
        border-radius: 25px;
        border: none;
        font-weight: bold;
        width: 100%;
        font-size: 16px;
        transition: 0.3s;
        cursor: pointer;
    }

        .btn-submit:hover {
            background-color: #26543e; /* Màu xanh đậm hơn khi hover */
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(50, 110, 81, 0.3);
        }

    /* Nút Quay lại */
    .back-link {
        display: inline-block;
        margin-top: 20px;
        color: #888;
        text-decoration: none;
        transition: 0.3s;
    }

        .back-link:hover {
            color: #326e51;
        }

    /* Căn chỉnh khoảng cách các nhóm form */
    .form-group {
        margin-bottom: 20px;
        width:700px;
    }
</style>

<div class="create-card">
    <h2>Thêm Nhân Viên Mới</h2>
    <h4>Nhập thông tin chi tiết bên dưới</h4>
    <hr />

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-group">
                @Html.LabelFor(model => model.PK_sMaNV, "Mã nhân viên", htmlAttributes: new { @class = "control-label col-md-3" })
                <div class="col-md-9">
                    @Html.EditorFor(model => model.PK_sMaNV, new { htmlAttributes = new { @class = "form-control", placeholder = "Ví dụ: NV01" } })
                    @Html.ValidationMessageFor(model => model.PK_sMaNV, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.sTenNV, "Họ và tên", htmlAttributes: new { @class = "control-label col-md-3" })
                <div class="col-md-9">
                    @Html.EditorFor(model => model.sTenNV, new { htmlAttributes = new { @class = "form-control", placeholder = "Nhập tên nhân viên" } })
                    @Html.ValidationMessageFor(model => model.sTenNV, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.sSDT, "Số điện thoại", htmlAttributes: new { @class = "control-label col-md-3" })
                <div class="col-md-9">
                    @Html.EditorFor(model => model.sSDT, new { htmlAttributes = new { @class = "form-control", placeholder = "09x xxx xxxx" } })
                    @Html.ValidationMessageFor(model => model.sSDT, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.sVaiTro, "Chức vụ", htmlAttributes: new { @class = "control-label col-md-3" })
                <div class="col-md-9">
                    @Html.EditorFor(model => model.sVaiTro, new { htmlAttributes = new { @class = "form-control", placeholder = "Bán hàng / Thu ngân..." } })
                    @Html.ValidationMessageFor(model => model.sVaiTro, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.sMatKhau, "Mật khẩu", htmlAttributes: new { @class = "control-label col-md-3" })
                <div class="col-md-9">
                    @Html.PasswordFor(model => model.sMatKhau, new { @class = "form-control", placeholder = "Nhập mật khẩu" })
                    @Html.ValidationMessageFor(model => model.sMatKhau, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.sPhanQuyen, "Phân quyền", htmlAttributes: new { @class = "control-label col-md-3" })
                <div class="col-md-9">
                    @Html.DropDownListFor(model => model.sPhanQuyen, new SelectList(new[] { "Admin", "NhanVien" }), "-- Chọn quyền hạn --", new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.sPhanQuyen, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.fLuong, "Lương cơ bản", htmlAttributes: new { @class = "control-label col-md-3" })
                <div class="col-md-9">
                    @Html.EditorFor(model => model.fLuong, new { htmlAttributes = new { @class = "form-control", type = "number" } })
                    @Html.ValidationMessageFor(model => model.fLuong, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                <div class="col-md-offset-3 col-md-9">
                    <button type="submit" class="btn-submit">
                        <i class="glyphicon glyphicon-save"></i> HOÀN TẤT THÊM MỚI
                    </button>
                </div>
            </div>
        </div>
    }

    <div class="text-center">
        <a href="@Url.Action("Index")" class="back-link">
            <i class="glyphicon glyphicon-arrow-left"></i> Quay lại danh sách
        </a>
    </div>
</div>