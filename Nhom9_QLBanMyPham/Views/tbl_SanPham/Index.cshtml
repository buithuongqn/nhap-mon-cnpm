@model IEnumerable<Nhom9_QLBanMyPham.Models.tbl_SanPham>

@{
    ViewBag.Title = "Quản Lý Sản Phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* 1. CẤU TRÚC CHÍNH */
    .manage-container {
        width: 100%;
        padding: 30px;
        background-color: #fff;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0,0,0,0.07);
        margin-top: 10px;
        box-sizing: border-box;
    }

    body {
        background-color: #f4f7f6;
        font-family: 'Segoe UI', Arial, sans-serif;
    }

    /* 2. TIÊU ĐỀ */
    .header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    .header-title h2 {
        color: #326e51;
        font-weight: 800;
        margin: 0;
        font-size: 32px;
        border-left: 5px solid #326e51;
        padding-left: 15px;
    }

    /* 3. THẺ THỐNG KÊ */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: #fff;
        padding: 20px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: 0.3s;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

    .stat-info p {
        color: #64748b;
        font-size: 14px;
        margin: 0;
        font-weight: 600;
        text-transform: uppercase;
    }

    .stat-info h3 {
        font-weight: 800;
        margin: 5px 0 0 0;
        color: #1a1a1a;
        font-size: 22px;
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    /* 4. THANH TÌM KIẾM & LỌC */
    .filter-section {
        background: #f8fafc;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        border: 1px solid #cbd5e1;
    }

    .filter-grid {
        display: grid;
        grid-template-columns: 4fr 2fr 1.5fr 1fr;
        gap: 15px;
        align-items: center;
    }

    .form-control-lg-custom {
        height: 45px;
        font-size: 15px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        padding: 10px 15px;
        width: 100%;
    }

    .btn-action {
        height: 45px;
        font-size: 15px;
        font-weight: 700;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: 0.3s;
        border: none;
        cursor: pointer;
    }

    .btn-submit {
        background-color: #326e51;
        color: white !important;
    }

        .btn-submit:hover {
            background-color: #26553e;
        }

    .btn-reset {
        background-color: #64748b;
        color: white !important;
        text-decoration: none;
    }

    /* 5. BẢNG DỮ LIỆU */
    .table-custom {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 10px;
    }

        .table-custom thead th {
            background: #f1f5f9;
            color: #326e51;
            font-weight: 700;
            padding: 15px;
            text-transform: uppercase;
            border: none;
        }

        .table-custom tbody tr {
            background: #fff;
            transition: 0.2s;
        }

            .table-custom tbody tr:hover {
                background: #f8fafc;
            }

        .table-custom tbody td {
            padding: 15px;
            vertical-align: middle;
            border-top: 1px solid #f1f5f9;
        }

    .img-product {
        width: 65px;
        height: 65px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background: #fff;
    }

    /* Badge Trạng thái */
    .badge-status {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        display: inline-block;
    }

    .status-instock {
        background: #dcfce7;
        color: #166534;
    }

    .status-low {
        background: #fef3c7;
        color: #92400e;
    }

    .status-out {
        background: #fee2e2;
        color: #991b1b;
    }

    .bg-light-green {
        background: #f0fff4;
        color: #326e51;
    }

    .bg-light-blue {
        background: #ebf8ff;
        color: #2b6cb0;
    }

    .bg-light-orange {
        background: #fffaf0;
        color: #c05621;
    }

    .bg-light-red {
        background: #fff5f5;
        color: #c53030;
    }

    .action-links a {
        font-size: 18px;
        margin: 0 8px;
        transition: 0.2s;
        display: inline-block;
        text-decoration: none;
    }

        .action-links a:hover {
            transform: scale(1.2);
        }
</style>

<div class="manage-container">
    <div class="header-flex">
        <div class="header-title">
            <h2><i class="fa fa-box"></i> QUẢN LÝ SẢN PHẨM</h2>
            <p class="text-muted" style="margin-left: 20px;">Hệ thống quản lý kho và danh mục mỹ phẩm</p>
        </div>
        <a href="@Url.Action("Create")" class="btn-submit btn-action" style="padding: 0 25px;">
            <i class="fa fa-plus"></i> THÊM SẢN PHẨM MỚI
        </a>
    </div>

    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-info">
                <p>Tổng sản phẩm</p>
                <h3>@ViewBag.TongSP</h3>
            </div>
            <div class="stat-icon bg-light-green"><i class="fa fa-cubes"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <p>Giá trị kho</p>
                <h3>@string.Format("{0:N0}", ViewBag.GiaTriKho ?? 0) đ</h3>
            </div>
            <div class="stat-icon bg-light-blue"><i class="fa fa-money"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <p>Sắp hết hàng</p>
                <h3>@ViewBag.SapHetHang</h3>
            </div>
            <div class="stat-icon bg-light-orange"><i class="fa fa-line-chart"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <p>Đã hết hàng</p>
                <h3>@ViewBag.HetHang</h3>
            </div>
            <div class="stat-icon bg-light-red"><i class="fa fa-exclamation-triangle"></i></div>
        </div>
    </div>

    <div class="filter-section">
        @using (Html.BeginForm("Index", "tbl_SanPham", FormMethod.Get))
        {
            <div class="filter-grid">
                <div>
                    <input type="text" name="searchString" class="form-control-lg-custom"
                           placeholder="Tìm theo tên hoặc mã SP..." value="@Request.QueryString["searchString"]">
                </div>
                <div>
                    @Html.DropDownList("maDM", (SelectList)ViewBag.maDM, "-- Chọn danh mục --", new { @class = "form-control-lg-custom" })
                </div>
                <button type="submit" class="btn-action btn-submit">
                    <i class="fa fa-search"></i> TÌM KIẾM
                </button>
                <a href="@Url.Action("Index")" class="btn-action btn-reset">
                    <i class="fa fa-refresh"></i> LÀM MỚI
                </a>
            </div>
        }
    </div>

    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th width="100">Mã SP</th>
                    <th width="400">Thông tin sản phẩm</th>
                    <th>Danh mục</th>
                    <th>Giá bán</th>
                    <th class="text-center">Tồn kho</th>
                    <th>Trạng thái</th>
                    <th width="150" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="font-weight:800; color: #326e51;">@item.PK_sMaSP</td>

                        <td>
                            <div style="display:flex; align-items:center; gap:12px;">
                                @{
                                    // Xử lý đường dẫn ảnh từ Database
                                    var imgPath = string.IsNullOrEmpty(item.sHinhAnh)
                                                  ? "/Content/Images/no-image.png"
                                                  : "/Content/Images/" + item.sHinhAnh;
                                }
                                <img src="@Url.Content(imgPath)"
                                     class="img-product"
                                     alt="@item.sTenSP"
                                     onerror="this.onerror=null;this.src='/Content/Images/no-image.png';" />

                                <div>
                                    <div style="font-weight:700; color: #1e293b; font-size: 16px;">@item.sTenSP</div>
                                    <small class="text-muted">NCC: @(item.tbl_NhaCungCap != null ? item.tbl_NhaCungCap.sTenNCC : "N/A")</small>
                                </div>
                            </div>
                        </td>

                        <td><span class="text-secondary">@(item.tbl_DanhMuc != null ? item.tbl_DanhMuc.sTenDM : "N/A")</span></td>

                        <td style="font-weight:800; color: #1a1a1a;">@string.Format("{0:N0}", item.fGiaBan) đ</td>

                        <td class="text-center" style="font-weight:700;">@item.iSoLuongTon</td>

                        <td>
                            @if (item.iSoLuongTon == 0)
                            {
                                <span class="badge-status status-out">HẾT HÀNG</span>
                            }
                            else if (item.iSoLuongTon <= 10)
                            {
                                <span class="badge-status status-low">SẮP HẾT</span>
                            }
                            else
                            {
                                <span class="badge-status status-instock">ĐANG BÁN</span>
                            }
                        </td>

                        <td class="text-center">
                            <div class="action-links">
                                <a href="@Url.Action("Details", new { id = item.PK_sMaSP })" class="text-primary" title="Xem chi tiết">
                                    <i class="fa fa-eye"></i>
                                </a>
                                <a href="@Url.Action("Edit", new { id = item.PK_sMaSP })" class="text-warning" title="Chỉnh sửa">
                                    <i class="fa fa-edit"></i>
                                </a>
                                <a href="@Url.Action("Delete", new { id = item.PK_sMaSP })" class="text-danger" title="Xóa sản phẩm">
                                    <i class="fa fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>