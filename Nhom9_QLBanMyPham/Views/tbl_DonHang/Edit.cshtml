@model Nhom9_QLBanMyPham.Models.tbl_DonHang

@{
    ViewBag.Title = "Chỉnh sửa đơn hàng #" + Model.PK_iMaDH;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary-color: #326e51;
        --primary-light: #f0fdf4;
        --text-dark: #1e293b; /* Màu xanh đen cho giá tiền */
        --border-color: #cbd5e1;
    }

    /* Tổng thể container */
    .edit-order-container {
        background-color: #fff;
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        margin-top: 20px;
        border: 1px solid var(--border-color);
        border-top: 8px solid var(--primary-color);
    }

    /* Tiêu đề */
    h2.text-header {
        color: var(--primary-color) !important;
        font-weight: 800;
        text-transform: uppercase;
        border-left: 6px solid var(--primary-color);
        padding-left: 15px;
        margin-bottom: 30px;
        letter-spacing: 1px;
    }

    /* Vùng thông tin chung */
    .info-section {
        background-color: var(--primary-light) !important;
        border: 1px solid #dcfce7 !important;
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 30px;
    }

        .info-section label {
            color: var(--primary-color);
            font-weight: 700;
            margin-bottom: 8px;
        }

    /* Form control */
    .form-control {
        border-radius: 10px;
        border: 1px solid var(--border-color);
        height: 40px;
    }

        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(50, 110, 81, 0.15);
        }

    /* Bảng chi tiết */
    .table-custom-theme {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border-color);
    }

        .table-custom-theme thead {
            background-color: var(--primary-color) !important;
        }

        .table-custom-theme th {
            color: white !important;
            border: none !important;
            text-align: center;
            padding: 15px !important;
            text-transform: uppercase;
            font-size: 13px;
            letter-spacing: 0.5px;
        }

        .table-custom-theme td {
            vertical-align: middle !important;
            text-align: center;
            border-top: 1px solid #f1f5f9 !important;
            padding: 12px !important;
            color: #475569;
        }

    /* Kết quả tìm kiếm */
    #searchResult {
        position: absolute;
        z-index: 100;
        background: white;
        width: 100%;
        border: 1px solid var(--primary-color);
        border-radius: 0 0 12px 12px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        display: none;
        max-height: 250px;
        overflow-y: auto;
    }

    .list-group-item-action:hover {
        background-color: var(--primary-light);
        color: var(--primary-color);
        font-weight: 600;
    }

    /* Tổng tiền và nút bấm */
    .summary-section {
        margin-top: 30px;
        padding: 30px;
        background-color: #f8fafc;
        border-radius: 15px;
        border: 2px dashed var(--primary-color);
    }

    #spTongTien {
        color: var(--text-dark) !important; /* Đổi từ đỏ sang xanh đen */
        font-weight: 800;
        font-size: 1.4em;
    }

    .btn-update {
        background-color: var(--primary-color) !important;
        border: none !important;
        padding: 12px 35px;
        border-radius: 30px;
        font-weight: 700;
        transition: 0.3s;
        color: white !important;
    }

        .btn-update:hover {
            background-color: var(--primary-hover) !important;
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(50, 110, 81, 0.3);
        }

    .btn-back {
        border-radius: 30px;
        padding: 12px 25px;
        margin-right: 15px;
        background-color: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        font-weight: 600;
        text-decoration: none !important;
    }

    .btn-delete-row {
        background-color: #fee2e2;
        color: #dc2626;
        border: none;
        padding: 8px 12px;
        border-radius: 8px;
        transition: 0.2s;
    }

        .btn-delete-row:hover {
            background-color: #fecaca;
        }

    h4.section-title {
        color: var(--primary-color);
        font-weight: 700;
        margin-top: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
</style>

<div class="container">
    <div class="edit-order-container">
        <h2 class="text-header">Chỉnh Sửa Đơn Hàng #@Model.PK_iMaDH</h2>

        <div class="row info-section">
            <div class="col-md-4">
                <label><i class="fa fa-user"></i> Khách hàng:</label>
                @Html.DropDownList("FK_sMaKH_DonHang", (SelectList)ViewBag.FK_sMaKH_DonHang, new { @class = "form-control", id = "cboKhachHang" })
            </div>
            <div class="col-md-4">
                <label><i class="fa fa-calendar-alt"></i> Ngày lập:</label>
                <input type="text" class="form-control" value="@Model.dNgayLap.Value.ToString("dd/MM/yyyy HH:mm")" readonly style="background-color: #e2e8f0;" />
            </div>
            <div class="col-md-4">
                <label><i class="fa fa-id-card"></i> Nhân viên phụ trách:</label>
                <input type="text" class="form-control" value="@Model.tbl_NguoiDung.sTenNV" readonly style="background-color: #e2e8f0;" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <h4 class="section-title"><i class="fa fa-cart-plus"></i> Thêm sản phẩm vào đơn</h4>
                <div style="position:relative; margin-bottom: 20px;">
                    <input type="text" id="txtSearch" class="form-control" placeholder="Tìm kiếm tên sản phẩm mỹ phẩm..." autocomplete="off" />
                    <div id="searchResult"></div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-custom-theme" id="tblChiTiet">
                <thead>
                    <tr>
                        <th width="100">Mã SP</th>
                        <th class="text-left">Tên sản phẩm</th>
                        <th width="120">Số lượng</th>
                        <th>Đơn giá</th>
                        <th>Thành tiền</th>
                        <th width="80">Xóa</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ct in Model.tbl_CTDonHang)
                    {
                        <tr data-ma="@ct.PK_sMaSP_CTDonHang">
                            <td class="font-weight-bold">@ct.PK_sMaSP_CTDonHang</td>
                            <td class="text-left" style="font-weight: 600; color: var(--text-dark);">
                                @(ct.tbl_SanPham != null ? ct.tbl_SanPham.sTenSP : "Sản phẩm cũ")
                            </td>
                            <td>
                                <input type="number" class="form-control sl text-center" value="@ct.iSoLuongBan" min="1" onchange="UpdateMoney()" style="width: 80px; margin: 0 auto;">
                            </td>
                            <td class="gia">@ct.fGiaBanLucDo</td>
                            <td class="thanhtien" style="font-weight: 800; color: var(--text-dark);">
                                @(ct.iSoLuongBan * ct.fGiaBanLucDo)
                            </td>
                            <td>
                                <button class="btn-delete-row" onclick="$(this).closest('tr').remove(); UpdateMoney();">
                                    <i class="fa fa-trash-alt"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="text-right summary-section">
            <h3 style="margin-top:0;">
                <span style="font-size: 16px; color: var(--primary-color); text-transform: uppercase;">Tổng số tiền thanh toán:</span><br />
                <span id="spTongTien">@string.Format("{0:N0}", Model.fTongTien)</span> <small>VNĐ</small>
            </h3>
            <hr />
            <a href="@Url.Action("Index")" class="btn-back">
                <i class="fa fa-arrow-left"></i> QUAY LẠI
            </a>
            <button class="btn-update" onclick="LuuCapNhat()">
                <i class="fa fa-save"></i> LƯU THAY ĐỔI
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // LOGIC TÌM KIẾM
        $('#txtSearch').keyup(function () {
            let key = $(this).val();
            if (key.length >= 1) {
                $.get('/tbl_SanPham/SearchProduct', { name: key }, function (data) {
                    let items = "";
                    data.forEach(x => {
                        items += `<div class='list-group-item list-group-item-action' style='cursor:pointer; padding: 12px;' onclick="AddRow('${x.MaSP}', '${x.TenSP}', ${x.Gia})">
                                    <i class='fa fa-plus-circle text-success'></i> <b>${x.TenSP}</b> - <span style='color: var(--text-dark); font-weight: 700;'>${x.Gia.toLocaleString()}đ</span>
                                  </div>`;
                    });
                    $('#searchResult').html(items).show();
                });
            } else { $('#searchResult').hide(); }
        });

        // THÊM DÒNG MỚI
        function AddRow(ma, ten, gia) {
            let row = `<tr data-ma="${ma}">
                        <td class="font-weight-bold">${ma}</td>
                        <td class="text-left" style="font-weight: 600; color: var(--text-dark);">${ten}</td>
                        <td><input type="number" class="form-control sl text-center" value="1" min="1" onchange="UpdateMoney()" style="width: 80px; margin: 0 auto;"></td>
                        <td class="gia">${gia}</td>
                        <td class="thanhtien" style="font-weight: 800; color: var(--text-dark);">${gia}</td>
                        <td><button class="btn-delete-row" onclick="$(this).closest('tr').remove(); UpdateMoney();"><i class="fa fa-trash-alt"></i></button></td>
                    </tr>`;
            $('#tblChiTiet tbody').append(row);
            $('#searchResult').hide();
            $('#txtSearch').val('');
            UpdateMoney();
        }

        // CẬP NHẬT TIỀN
        function UpdateMoney() {
            let total = 0;
            $('#tblChiTiet tbody tr').each(function () {
                let sl = parseFloat($(this).find('.sl').val()) || 0;
                let gia = parseFloat($(this).find('.gia').text()) || 0;
                let tt = sl * gia;
                $(this).find('.thanhtien').text(tt);
                total += tt;
            });
            $('#spTongTien').text(total.toLocaleString());
        }

        // GỬI DỮ LIỆU CẬP NHẬT
        function LuuCapNhat() {
            let dsSanPham = [];
            $('#tblChiTiet tbody tr').each(function () {
                dsSanPham.push({
                    MaSP: $(this).data('ma'),
                    SoLuong: $(this).find('.sl').val(),
                    DonGia: $(this).find('.gia').text()
                });
            });

            if (dsSanPham.length === 0) {
                alert("Đơn hàng không được để trống!");
                return;
            }

            let model = {
                MaKH: $('#cboKhachHang').val(),
                DanhSachSanPham: dsSanPham
            };

            if(!confirm("Bạn có chắc chắn muốn lưu các thay đổi này?")) return;

            $.ajax({
                url: '/tbl_DonHang/EditNew/' + @Model.PK_iMaDH,
                type: 'POST',
                data: JSON.stringify(model),
                contentType: 'application/json',
                success: function (res) {
                    if (res.ok) {
                        alert("Cập nhật đơn hàng thành công!");
                        window.location.href = "/tbl_DonHang/Index";
                    } else { alert(res.msg); }
                },
                error: function() {
                    alert("Có lỗi xảy ra trong quá trình xử lý!");
                }
            });
        }
    </script>
}