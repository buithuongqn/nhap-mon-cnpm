@model IEnumerable<Nhom9_QLBanMyPham.Models.tbl_DonHang>

@{
    ViewBag.Title = "Quản lý Đơn hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int stt = 1;
}

<style>
    /* 1. CẤU TRÚC CHÍNH */
    .manage-container {
        width: 100%;
        padding: 30px;
        background-color: #fff;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0,0,0,0.07);
        margin-top: 10px;
        box-sizing: border-box;
    }

    body {
        background-color: #f4f7f6;
        font-family: 'Segoe UI', Arial, sans-serif;
    }

    /* 2. TIÊU ĐỀ */
    .header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    .header-title h2 {
        color: #326e51;
        font-weight: 800;
        margin: 0;
        font-size: 35px;
        border-left: 6px solid #326e51;
        padding-left: 15px;
    }

    /* 3. THỐNG KÊ */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: #fff;
        padding: 25px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .stat-info p {
        color: #64748b;
        font-size: 16px;
        margin: 0;
        font-weight: 600;
    }

    .stat-info h3 {
        font-weight: 800;
        margin: 5px 0 0 0;
        color: #1a1a1a;
        font-size: 28px;
    }

    .stat-icon {
        width: 55px;
        height: 55px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .bg-light-green {
        background: #f0fff4;
        color: #326e51;
    }

    .bg-light-blue {
        background: #ebf8ff;
        color: #2b6cb0;
    }

    .bg-light-orange {
        background: #fffaf0;
        color: #c05621;
    }

    .bg-light-red {
        background: #fff5f5;
        color: #c53030;
    }

    /* 4. THANH TÌM KIẾM */
    .filter-section {
        background: #f8fafc;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        border: 1px solid #cbd5e1;
    }

    .filter-grid {
        display: grid;
        grid-template-columns: 4fr 1.5fr 1fr;
        gap: 15px;
        align-items: center;
    }

    .form-control-lg-custom {
        height: 50px;
        font-size: 17px;
        border-radius: 8px;
        border: 2px solid #cbd5e1;
        padding: 10px 15px;
        width: 100%;
    }

    .btn-action {
        height: 50px;
        font-size: 16px;
        font-weight: 700;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: 0.3s;
        border: none;
    }

    .btn-submit {
        background-color: #326e51;
        color: white !important;
    }

        .btn-submit:hover {
            background-color: #26553e;
            transform: translateY(-2px);
        }

    .btn-reset {
        background-color: #64748b;
        color: white !important;
        text-decoration: none;
    }

    /* 5. BẢNG DỮ LIỆU */
    .table-custom thead th {
        background: #f1f5f9;
        color: #326e51;
        font-weight: 700;
        font-size: 16px;
        padding: 18px;
        text-transform: uppercase;
        border: none;
    }

    .table-custom tbody td {
        padding: 20px 18px;
        vertical-align: middle;
        font-size: 17px;
        border-bottom: 1px solid #f1f5f9;
    }

    /* Badge Trạng thái */
    .badge-status {
        padding: 8px 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 700;
    }

    .status-paid {
        background: #dcfce7;
        color: #166534;
    }

    /* Action Links */
    .action-links a {
        font-size: 20px;
        margin: 0 10px;
        transition: 0.2s;
        display: inline-block;
        text-decoration: none;
        cursor: pointer;
    }

        .action-links a:hover {
            transform: scale(1.2);
        }
</style>

<div class="manage-container">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="header-flex">
        <div class="header-title">
            <h2><i class="fa fa-list-alt"></i> Danh Sách Đơn Hàng</h2>
            <p class="text-muted mt-2">Quản lý và theo dõi trạng thái giao dịch khách hàng</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-submit btn-action" style="width: 210px;">
            <i class="fa fa-plus"></i> Tạo đơn hàng mới
        </a>
    </div>

    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-info">
                <p>Tổng đơn hàng</p>
                <h3>@Model.Count()</h3>
            </div>
            <div class="stat-icon bg-light-green"><i class="fa fa-shopping-cart"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <p>Tổng doanh thu</p>
                <h3>@string.Format("{0:N0}", Model.Sum(x => x.fTongTien)) đ</h3>
            </div>
            <div class="stat-icon bg-light-blue"><i class="fa fa-money"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <p>Đơn hoàn thành</p>
                <h3>@Model.Count()</h3>
            </div>
            <div class="stat-icon bg-light-orange"><i class="fa fa-check-circle"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <p>Khách hàng mới</p>
                <h3>@Model.Select(x => x.FK_sMaKH_DonHang).Distinct().Count()</h3>
            </div>
            <div class="stat-icon bg-light-red"><i class="fa fa-users"></i></div>
        </div>
    </div>

    <div class="filter-section">
        <div class="filter-grid">
            <div class="search-box">
                <input type="text" class="form-control-lg-custom" placeholder="Tìm theo mã đơn hoặc tên khách hàng...">
            </div>
            <button class="btn-action btn-submit">
                <i class="fa fa-search"></i> Tìm kiếm
            </button>
            <a href="@Url.Action("Index")" class="btn-action btn-reset">
                <i class="fa fa-refresh"></i> Làm mới
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-custom">
            <thead>
                <tr>
                    <th width="80" class="text-center">STT</th>
                    <th>Thông tin khách hàng</th>
                    <th>Người lập</th>
                    <th>Thời gian</th>
                    <th>Tổng tiền</th>
                    <th class="text-center">Trạng thái</th>
                    <th width="150" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center" style="font-weight:800; color: #326e51;">@(stt++)</td>
                        <td>
                            <div style="font-weight:700; color: #1e293b; font-size: 18px;">@item.tbl_KhachHang.sTenKH</div>
                            <small class="text-muted"><i class="fa fa-phone"></i> @item.tbl_KhachHang.sSDT</small>
                        </td>
                        <td><span class="text-secondary">@item.tbl_NguoiDung.sTenNV</span></td>
                        <td>
                            <div style="font-weight:600;">@String.Format("{0:HH:mm}", item.dNgayLap)</div>
                            <small class="text-muted">@String.Format("{0:dd/MM/yyyy}", item.dNgayLap)</small>
                        </td>
                        <td style="font-weight:800; color: #1a1a1a;">@string.Format("{0:N0}", item.fTongTien) đ</td>
                        <td class="text-center">
                            <span class="badge-status status-paid">Đã thanh toán</span>
                        </td>
                        <td class="text-center">
                            <div class="action-links">
                                <a href="@Url.Action("Details", new { id = item.PK_iMaDH })" class="text-primary" title="Xem">
                                    <i class="fa fa-eye"></i>
                                </a>

                                <a onclick="PrintOrderDirect('@item.PK_iMaDH')" class="text-warning" title="In hóa đơn">
                                    <i class="fa fa-print"></i>
                                </a>

                                <a href="@Url.Action("Delete", new { id = item.PK_iMaDH })" class="text-danger" title="Xóa" onclick="return confirm('Bạn có chắc chắn muốn xóa đơn hàng này?')">
                                    <i class="fa fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<iframe id="printFrame" style="display:none;"></iframe>

@section Scripts {
    <script>
        function PrintOrderDirect(id) {
            // Hiển thị loading nhẹ nếu cần
            var iframe = document.getElementById('printFrame');

            // Gọi đến Action Details của Controller
            var url = '/tbl_DonHang/Details/' + id;

            iframe.src = url;

            iframe.onload = function () {
                // Đợi nội dung tải xong hoàn toàn
                setTimeout(function () {
                    iframe.contentWindow.focus();
                    iframe.contentWindow.print();
                }, 500); // Delay 500ms để đảm bảo CSS/Images trong iframe được render
            };
        }

        // Script tìm kiếm cơ bản (nếu bạn muốn lọc nhanh tại client)
        $('.search-box input').on('keyup', function () {
            var value = $(this).val().toLowerCase();
            $(".table-custom tbody tr").filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        });
    </script>
}