@model Nhom9_QLBanMyPham.Models.tbl_DonHang

@{
    ViewBag.Title = "Lập đơn hàng";
}

<style>
    :root {
        --primary-color: #326e51;
        --primary-light: #f0fdf4;
        --primary-hover: #26553e;
        --danger: #d32f2f;
        --border-color: #e2e8f0;
    }

    body {
        background-color: #f4f7f6;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* Tổng thể container */
    .order-container {
        background-color: #fff;
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        margin-top: 30px;
        margin-bottom: 50px;
        border: none;
    }

    /* Tiêu đề chính */
    .title-green {
        color: var(--primary-color) !important;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 30px;
        position: relative;
        padding-bottom: 10px;
    }

        .title-green::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 4px;
            background: var(--primary-color);
            border-radius: 2px;
        }

    /* Vùng thông tin chung */
    .info-section {
        background-color: var(--primary-light) !important;
        border: 1px solid #dcfce7 !important;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 30px;
    }

        .info-section label {
            color: var(--primary-color);
            font-weight: 700;
            margin-bottom: 8px;
            display: block;
            font-size: 14px;
        }

    /* Input và Select */
    .form-control {
        border-radius: 10px;
        border: 1px solid var(--border-color);
        height: 45px;
        font-size: 15px;
    }

        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(50, 110, 81, 0.1);
        }

    /* Bảng chi tiết sản phẩm */
    .table-custom {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border-color);
        margin-top: 20px;
    }

        .table-custom thead {
            background-color: var(--primary-color) !important;
        }

            .table-custom thead th {
                color: white !important;
                border: none;
                text-align: center;
                padding: 15px;
                text-transform: uppercase;
                font-size: 13px;
                letter-spacing: 0.5px;
            }

        .table-custom tbody td {
            vertical-align: middle;
            text-align: center;
            padding: 15px;
            border-top: 1px solid #f1f5f9;
            color: #334155;
            font-weight: 500;
        }

    /* Tìm kiếm nhanh */
    #searchResult {
        position: absolute;
        z-index: 1000;
        background: white;
        width: 100%;
        border: 1px solid var(--primary-color);
        border-top: none;
        border-radius: 0 0 12px 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        display: none;
        max-height: 250px;
        overflow-y: auto;
    }

    .list-group-item-action {
        padding: 12px 20px;
        cursor: pointer;
        transition: 0.2s;
        border-bottom: 1px solid #f1f5f9;
    }

        .list-group-item-action:hover {
            background-color: var(--primary-light);
            color: var(--primary-color);
        }

    /* Phần tổng tiền */
    .total-card {
        background: #f8fafc;
        padding: 20px;
        border-radius: 12px;
        margin-top: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .total-label {
        color: #64748b;
        font-weight: 600;
        margin: 0;
    }

    #spTongTien {
        color: var(--danger) !important;
        font-size: 36px;
        font-weight: 800;
    }

    /* Nút bấm */
    .btn-confirm {
        background-color: var(--primary-color);
        color: white;
        padding: 15px 40px;
        border-radius: 12px;
        font-weight: 700;
        transition: 0.3s;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-confirm:hover {
            background-color: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(50, 110, 81, 0.25);
            color: white;
        }

    .btn-refresh {
        background-color: #fff;
        color: #64748b;
        border: 2px solid var(--border-color);
        border-radius: 12px;
        padding: 15px 25px;
        font-weight: 700;
        margin-right: 15px;
        transition: 0.3s;
    }

        .btn-refresh:hover {
            background-color: #f1f5f9;
            color: var(--danger);
            border-color: var(--danger);
        }

    .btn-remove-item {
        background-color: #fee2e2;
        border: none;
        color: #ef4444;
        width: 35px;
        height: 35px;
        border-radius: 8px;
        transition: 0.2s;
    }

        .btn-remove-item:hover {
            background-color: #ef4444;
            color: white;
        }

    h4 {
        color: var(--primary-color);
        font-weight: 700;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
</style>

<div class="container order-container">
    <h2 class="title-green text-center">Lập Đơn Hàng Mới</h2>

    <div class="row info-section">
        <div class="col-md-3">
            <label><i class="fa fa-calendar"></i> Ngày lập</label>
            <input type="text" class="form-control" value="@DateTime.Now.ToString("dd/MM/yyyy")" readonly style="background-color: #e9ecef" />
        </div>
        <div class="col-md-3">
            <label><i class="fa fa-user-tie"></i> Nhân viên lập</label>
            @* Sửa dòng value dưới đây để lấy từ Session *@
            <input type="text" class="form-control"
                   value="@(Session["MaNV"] != null ? Session["MaNV"] + " - " + Session["TenNV"] : "Chưa đăng nhập")"
                   readonly style="background-color: #e9ecef" />
        </div>
        <div class="col-md-6">
            <label><i class="fa fa-address-book"></i> Đối tượng khách hàng</label>
            @Html.DropDownList("MaKH", (SelectList)ViewBag.sMaKH, "-- Chọn khách hàng thanh toán --", new { @class = "form-control", id = "cboKhachHang" })
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <h4><i class="fa fa-search"></i> Quét mã hoặc tìm sản phẩm</h4>
            <div style="position:relative;">
                <input type="text" id="txtSearch" class="form-control" placeholder="Nhập tên sản phẩm hoặc mã SP..." autocomplete="off" style="height: 55px; font-size: 16px; padding-left: 20px;" />
                <div id="searchResult"></div>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-custom mt-3" id="tblChiTiet">
            <thead>
                <tr>
                    <th width="120">Mã SP</th>
                    <th>Tên sản phẩm</th>
                    <th width="150">Số lượng</th>
                    <th>Đơn giá</th>
                    <th>Thành tiền</th>
                    <th width="80">Xóa</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>

    <div class="total-card">
        <div>
            <span class="total-label">Vui lòng kiểm tra kỹ thông tin trước khi lưu đơn</span>
        </div>
        <div class="text-right">
            <h3 class="total-label" style="display:inline-block; margin-right: 15px;">Tổng cộng:</h3>
            <span id="spTongTien">0</span> <span style="font-size: 20px; font-weight: 800; color: var(--danger)">VNĐ</span>
        </div>
    </div>

    <div class="text-right mt-4">
        <button class="btn btn-refresh" onclick="HuyDonHang()">
            <i class="fa fa-sync-alt"></i> Hủy đơn & Làm mới
        </button>
        <button class="btn btn-confirm" onclick="LuuDonHang()">
            <i class="fa fa-check-circle"></i> XÁC NHẬN LƯU ĐƠN HÀNG
        </button>
    </div>
</div>

@section Scripts {
    <script>
        // TÌM KIẾM SẢN PHẨM
        $('#txtSearch').keyup(function () {
            let key = $(this).val();
            if (key.length >= 1) {
                $.get('/tbl_SanPham/SearchProduct', { name: key }, function (data) {
                    let items = "";
                    data.forEach(x => {
                        items += `<div class='list-group-item-action' onclick="AddRow('${x.MaSP}', '${x.TenSP}', ${x.Gia})">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span><b>${x.MaSP}</b> - ${x.TenSP}</span>
                                                <span class='badge' style="background: var(--primary-color); color: white">${x.Gia.toLocaleString()}đ</span>
                                            </div>
                                          </div>`;
                    });
                    $('#searchResult').html(items).show();
                });
            } else {
                $('#searchResult').hide();
            }
        });

        // THÊM DÒNG
        function AddRow(ma, ten, gia) {
            // Kiểm tra trùng sản phẩm
            let isExist = false;
            $('#tblChiTiet tbody tr').each(function () {
                if ($(this).data('ma') == ma) {
                    let currentSl = parseInt($(this).find('.sl').val());
                    $(this).find('.sl').val(currentSl + 1);
                    isExist = true;
                }
            });

            if (!isExist) {
                let row = `<tr data-ma="${ma}">
                                    <td><span class="badge badge-light" style="font-size:14px">${ma}</span></td>
                                    <td class="text-left">${ten}</td>
                                    <td><input type="number" class="form-control sl text-center" value="1" min="1" onchange="UpdateMoney()" style="height:35px"></td>
                                    <td class="gia" data-val="${gia}">${gia.toLocaleString()}</td>
                                    <td class="thanhtien font-weight-bold" style="color: var(--primary-color)">${gia.toLocaleString()}</td>
                                    <td><button class="btn-remove-item" onclick="$(this).closest('tr').remove(); UpdateMoney();"><i class="fa fa-times"></i></button></td>
                                </tr>`;
                $('#tblChiTiet tbody').append(row);
            }

            $('#searchResult').hide();
            $('#txtSearch').val('');
            UpdateMoney();
        }

        // TÍNH TIỀN
        function UpdateMoney() {
            let total = 0;
            $('#tblChiTiet tbody tr').each(function () {
                let sl = $(this).find('.sl').val();
                let gia = $(this).find('.gia').data('val');
                let tt = sl * gia;
                $(this).find('.thanhtien').text(tt.toLocaleString());
                total += tt;
            });
            $('#spTongTien').text(total.toLocaleString());
        }

        // HỦY ĐƠN
        function HuyDonHang() {
            if (confirm("Xóa toàn bộ sản phẩm đã chọn?")) {
                location.reload();
            }
        }

        // LƯU ĐƠN HÀNG (Giữ nguyên Logic cũ của bạn)
        function LuuDonHang() {
            let khachHang = $('#cboKhachHang').val();
            if (!khachHang) {
                alert("Vui lòng chọn khách hàng!");
                return;
            }

            let dsSanPham = [];
            $('#tblChiTiet tbody tr').each(function () {
                dsSanPham.push({
                    MaSP: $(this).data('ma'),
                    SoLuong: $(this).find('.sl').val(),
                    DonGia: $(this).find('.gia').data('val')
                });
            });

            if (dsSanPham.length === 0) {
                alert("Vui lòng chọn ít nhất một sản phẩm!");
                return;
            }

            let model = {
                MaKH: khachHang,
                DanhSachSanPham: dsSanPham
            };

            $.ajax({
                url: '/tbl_DonHang/CreateNew',
                type: 'POST',
                data: JSON.stringify(model),
                contentType: 'application/json',
                success: function (res) {
                    if (res.ok) {
                        alert("🎉 Đã lưu đơn hàng thành công!");
                        window.location.href = "/tbl_DonHang/Index";
                    } else {
                        alert("Lỗi: " + res.msg);
                    }
                }
            });
        }
    </script>
}